+uint64
+count_free_mem(void)
+{
+  struct run *r;
+  uint64 count = 0;
+
+  acquire(&kmem.lock); // Khóa để đảm bảo an toàn đa nhân (multicore)
+  r = kmem.freelist;   // Lấy danh sách các trang trống
