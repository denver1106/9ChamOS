+uint64
+count_processes(void)
+{
+  struct proc *p;
+  uint64 count = 0;
+
+  for(p = proc; p < &proc[NPROC]; p++){
+    if(p->state != UNUSED) // Nếu slot này đang được sử dụng
+      count++;
+  }
+  return count;
+}
